# Never place real keys in this file. Generate separate V2 wallets.
PHAROS_DEPLOYER_PRIVATE_KEY=
PHAROS_DEPLOYER_ADDRESS=

# Keeper/Reporter wallet must be different from the deployer wallet.
PHAROS_KEEPER_PRIVATE_KEY=
PHAROS_REPORTER_ADDRESS=

# Pharos Atlantic RPC endpoint
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_EXPLORER_URL=https://atlantic.pharosscan.xyz

# Filled after DeployV2.s.sol
RISK_REPORT_REGISTRY_ADDRESS=
MARKET_REGIME_GATE_V2_ADDRESS=
YIELD_DECAY_GATE_ADDRESS=
PROTOCOL_REGISTRY_V2_ADDRESS=
SLIPPAGE_GUARD_V2_ADDRESS=
EXECUTION_ENGINE_V2_ADDRESS=
DEMO_TARGET_ADDRESS=

# Analytics API Config
PORT=3000
DATABASE_URL=file:./db.sqlite
