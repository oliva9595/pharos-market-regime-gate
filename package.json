    "packages/*",
    "services/*"
  ],
  "bin": {
    "pharos-cli": "./bin/cli.js",
    "pharos-mcp": "./bin/mcp-server.js"
  },
  "scripts": {
    "demo-web": "npx http-server -c-1 ./",
    "build": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:contracts": "C:\\Users\\XuanCanh\\.foundry\\bin\\forge.exe test",
    "typecheck": "tsc --noEmit -b tsconfig.json",
